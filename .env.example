# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/issuedb?schema=public"

# -----------------------------------------------------------------------------
# Autodesk Platform Services (APS)
# -----------------------------------------------------------------------------
APS_CLIENT_ID="your_aps_client_id"
APS_CLIENT_SECRET="your_aps_client_secret"
APS_URN="your_model_urn"

# -----------------------------------------------------------------------------
# Object Storage (MinIO)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="aps-issues"

# -----------------------------------------------------------------------------
# NextAuth / Security (Optional if used)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="your_nextauth_secret"
NEXTAUTH_URL="http://localhost:3000"
